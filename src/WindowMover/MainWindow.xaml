<Window x:Class="WindowMover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WindowMover.ViewModels"
        mc:Ignorable="d"
        Title="WindowMover — Monitor Layout Manager"
        Height="650" Width="1000" MinHeight="450" MinWidth="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        Topmost="{Binding IsTopmost}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📷 Capture Layout" Command="{Binding CaptureLayoutCommand}"
                            ToolTip="Update positions for open apps; preserve rules for closed apps"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                    <Button Content="🗑 Clear &amp; Capture" Command="{Binding ClearAndCaptureCommand}"
                            ToolTip="Replace entire profile with only the currently open apps"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                    <Button Content="▶ Apply Now" Command="{Binding ApplyNowCommand}"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0"
                            ToolTip="Move all windows to their assigned monitor positions" />
                    <Button Content="💾 Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource ActionButton}"
                            ToolTip="Save the current layout to the profile" />
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="WindowMover" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding CurrentSetupName, StringFormat='Active Profile: {0}'}"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content: Unassigned apps + Monitor columns -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: Unassigned apps -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Margin="0,0,6,0" Padding="12"
                    AllowDrop="True"
                    DragOver="UnassignedPanel_DragOver"
                    DragLeave="UnassignedPanel_DragLeave"
                    Drop="UnassignedPanel_Drop"
                    x:Name="UnassignedPanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="?" FontSize="12" FontWeight="Bold"
                                Padding="6,1" Background="Transparent"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="1" BorderBrush="{StaticResource TextSecondaryBrush}"
                                Cursor="Hand" VerticalAlignment="Center">
                            <Button.ToolTip>
                                <ToolTip MaxWidth="320" Placement="Right">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="Why do apps appear here?"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="&#x2022;  Newly opened app"
                                                       FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="No matching rule exists in the current profile."
                                                       FontSize="11" Margin="14,0,0,0" TextWrapping="Wrap"
                                                       Opacity="0.8" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="&#x2022;  Window title changed"
                                                       FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="The title changed between sessions, so the saved rule no longer matches."
                                                       FontSize="11" Margin="14,0,0,0" TextWrapping="Wrap"
                                                       Opacity="0.8" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="&#x2022;  Manually unassigned"
                                                       FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="You moved it here using the unlock button."
                                                       FontSize="11" Margin="14,0,0,0" TextWrapping="Wrap"
                                                       Opacity="0.8" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="&#x2022;  Monitor disconnected"
                                                       FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="The monitor it was assigned to is no longer connected."
                                                       FontSize="11" Margin="14,0,0,0" TextWrapping="Wrap"
                                                       Opacity="0.8" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="&#x2022;  Switched profiles"
                                                       FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="Running apps not included in the new profile appear here."
                                                       FontSize="11" Margin="14,0,0,0" TextWrapping="Wrap"
                                                       Opacity="0.8" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="&#x2022;  New profile created"
                                                       FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="A new profile starts empty, so all running apps appear here until assigned."
                                                       FontSize="11" Margin="14,0,0,0" TextWrapping="Wrap"
                                                       Opacity="0.8" />
                                        </StackPanel>
                                        <Border BorderThickness="0,1,0,0" BorderBrush="Gray"
                                                Padding="0,6,0,0">
                                            <TextBlock Text="Drag an app to a monitor to assign it, or click the trash icon to remove it from the profile."
                                                       FontSize="11" TextWrapping="Wrap"
                                                       FontStyle="Italic" Opacity="0.7" />
                                        </Border>
                                    </StackPanel>
                                </ToolTip>
                            </Button.ToolTip>
                        </Button>
                        <TextBlock Text="📋 Unassigned Apps"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding UnassignedApps}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             x:Name="UnassignedAppsList">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceLightBrush}"
                                        CornerRadius="4" Padding="10,8" Margin="0,2"
                                        Cursor="Hand"
                                        MouseMove="AppCard_MouseMove"
                                        Tag="{Binding}">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="🗑" FontSize="9" Padding="4,1"
                                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                                BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                                                ToolTip="Delete from profile (permanently remove this rule)"
                                                Click="DeleteUnassignedApp_Click" Tag="{Binding}" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="13" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ProcessName, StringFormat='({0})'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding WindowTitle}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       Visibility="{Binding WindowTitle, Converter={StaticResource NonEmptyToVisibleConverter}}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right panel: Monitor columns -->
            <ItemsControl Grid.Column="1"
                          ItemsSource="{Binding Monitors}"
                          x:Name="MonitorsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="8" Margin="6,0" Padding="12"
                                AllowDrop="True"
                                DragOver="MonitorPanel_DragOver"
                                DragLeave="MonitorPanel_DragLeave"
                                Drop="MonitorPanel_Drop"
                                Tag="{Binding}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Monitor header -->
                                <DockPanel Grid.Row="0">
                                    <Button DockPanel.Dock="Right" Content="?" FontSize="12" FontWeight="Bold"
                                            Padding="6,1" Background="Transparent"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderThickness="1" BorderBrush="{StaticResource TextSecondaryBrush}"
                                            Cursor="Hand" VerticalAlignment="Top">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320" Placement="Left">
                                                <StackPanel Margin="4">
                                                    <TextBlock Text="Monitor column"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               Margin="0,0,0,8" />

                                                    <TextBlock Text="DISPLAY INFO" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="CornflowerBlue" Margin="0,0,0,4" />
                                                    <StackPanel Margin="0,0,0,4">
                                                        <TextBlock Text="&#x2022;  Resolution shows the monitor's pixel dimensions"
                                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.8" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <TextBlock Text="&#x2022;  Built-in: True = laptop screen; False = external monitor (dock or cable)"
                                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.8" />
                                                    </StackPanel>

                                                    <TextBlock Text="ASSIGNING APPS" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="CornflowerBlue" Margin="0,0,0,4" />
                                                    <StackPanel Margin="0,0,0,4">
                                                        <TextBlock Text="&#x2022;  Drag apps from Unassigned or other monitors into this column"
                                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.8" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <TextBlock Text="&#x2022;  Moving a window to another monitor is detected automatically"
                                                                   FontSize="11" TextWrapping="Wrap" Opacity="0.8" />
                                                    </StackPanel>

                                                    <TextBlock Text="APP CARD CONTROLS" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="CornflowerBlue" Margin="0,0,0,4" />
                                                    <StackPanel Margin="0,0,0,4">
                                                        <TextBlock FontSize="11" TextWrapping="Wrap" Opacity="0.8">
                                                            <Run FontWeight="SemiBold">&#x25B2; &#x25BC;</Run>
                                                            <Run>Change ordering. Apps higher in the list appear in front when Apply Now is used.</Run>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4">
                                                        <TextBlock FontSize="11" TextWrapping="Wrap" Opacity="0.8">
                                                            <Run FontWeight="SemiBold">&#x1F513;</Run>
                                                            <Run>Unassign from this monitor. The rule moves to the Unassigned list but stays in the profile.</Run>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <TextBlock FontSize="11" TextWrapping="Wrap" Opacity="0.8">
                                                            <Run FontWeight="SemiBold">&#x1F5D1;</Run>
                                                            <Run>Delete from profile. Permanently removes this app rule.</Run>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <Border BorderThickness="0,1,0,0" BorderBrush="Gray"
                                                            Padding="0,6,0,0">
                                                        <TextBlock Text="If this monitor is disconnected, its assigned apps move to the Unassigned list."
                                                                   FontSize="11" TextWrapping="Wrap"
                                                                   FontStyle="Italic" Opacity="0.7" />
                                                    </Border>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}">
                                            <Run Text="🖥️ " />
                                            <Run Text="{Binding DisplayName, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                            <Run Text="{Binding Resolution, Mode=OneWay}" />
                                            <Run Text="{Binding IsBuiltIn, Mode=OneWay, StringFormat=' (Built-in: {0})'}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>

                                <Separator Grid.Row="1" Margin="0,8" Background="{StaticResource SurfaceLightBrush}" />

                                <!-- Assigned apps list -->
                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding AssignedApps}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceLightBrush}"
                                                    CornerRadius="4" Padding="10,8" Margin="0,2"
                                                    Cursor="Hand"
                                                    MouseMove="AppCard_MouseMove"
                                                    Tag="{Binding}">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="4,0,0,0">
                                                        <Button Content="▲" FontSize="9" Padding="4,1"
                                                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                                                BorderThickness="0" Cursor="Hand"
                                                                ToolTip="Move up (appears in front of apps below)"
                                                                Click="MoveAppUp_Click" Tag="{Binding}" />
                                                        <Button Content="🔓" FontSize="9" Padding="4,1"
                                                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                                                BorderThickness="0" Cursor="Hand"
                                                                ToolTip="Unassign from this monitor (keeps rule in profile)"
                                                                Click="UnassignApp_Click" Tag="{Binding}" />
                                                        <Button Content="🗑" FontSize="9" Padding="4,1"
                                                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                                                BorderThickness="0" Cursor="Hand"
                                                                ToolTip="Delete from profile (permanently remove this rule)"
                                                                Click="DeleteApp_Click" Tag="{Binding}" />
                                                        <Button Content="▼" FontSize="9" Padding="4,1"
                                                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                                                BorderThickness="0" Cursor="Hand"
                                                                ToolTip="Move down (appears behind apps above)"
                                                                Click="MoveAppDown_Click" Tag="{Binding}" />
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding ProcessName, StringFormat='({0})'}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding WindowTitle}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11" TextWrapping="Wrap"
                                                                   Visibility="{Binding WindowTitle, Converter={StaticResource NonEmptyToVisibleConverter}}" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- Empty state overlay -->
                                <TextBlock Grid.Row="2"
                                           Text="Drag apps here"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" FontStyle="Italic"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.6"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AssignedApps.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="12,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding UnsavedIndicator}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           Margin="12,0,0,0" />
                <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0">
                    <Hyperlink Click="About_Click"
                               Foreground="#607090" TextDecorations="None"
                               FontSize="11">About</Hyperlink>
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0">
                    <Hyperlink Click="ViewLog_Click"
                               Foreground="#607090" TextDecorations="None"
                               FontSize="11">Log</Hyperlink>
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0">
                    <Hyperlink Click="Profiles_Click"
                               Foreground="#607090" TextDecorations="None"
                               FontSize="11">Profiles</Hyperlink>
                </TextBlock>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
