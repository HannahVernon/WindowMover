<Window x:Class="WindowMover.App.ProfilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Profiles"
        Width="520" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinWidth="400" MinHeight="280"
        Background="#1E1E2E"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Saved Profiles"
                   Foreground="White" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <ListView Grid.Row="1" x:Name="ProfileList"
                  Background="#252538" BorderBrush="#3A3A5A" BorderThickness="1"
                  Foreground="#E0E0E0" FontSize="13"
                  SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="180"
                                    DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Monitors" Width="70"
                                    DisplayMemberBinding="{Binding MonitorCount}" />
                    <GridViewColumn Header="Rules" Width="60"
                                    DisplayMemberBinding="{Binding RuleCount}" />
                    <GridViewColumn Header="Active" Width="55"
                                    DisplayMemberBinding="{Binding ActiveIndicator}" />
                    <GridViewColumn Header="Last Modified" Width="120"
                                    DisplayMemberBinding="{Binding LastModified}" />
                </GridView>
            </ListView.View>
            <ListView.Resources>
                <Style TargetType="GridViewColumnHeader">
                    <Setter Property="Background" Value="#2A2A42" />
                    <Setter Property="Foreground" Value="#A0A8C0" />
                    <Setter Property="BorderBrush" Value="#3A3A5A" />
                    <Setter Property="Padding" Value="8,4" />
                </Style>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="#E0E0E0" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3A3A5A" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#303048" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Resources>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Rename" Click="Rename_Click"
                    Padding="14,7" Margin="0,0,8,0"
                    Background="#3A3A5A" Foreground="#E0E0E0"
                    BorderBrush="#5A5A8A" Cursor="Hand" />
            <Button Content="Delete" Click="Delete_Click"
                    Padding="14,7" Margin="0,0,8,0"
                    Background="#5A2A2A" Foreground="#E0E0E0"
                    BorderBrush="#8A4A4A" Cursor="Hand" />
            <Button Content="Close" Click="Close_Click" IsDefault="True"
                    Padding="14,7"
                    Background="#508CF0" Foreground="White"
                    BorderBrush="#6EA0FF" Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
