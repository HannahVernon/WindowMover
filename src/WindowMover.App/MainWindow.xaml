<Window x:Class="WindowMover.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WindowMover.App.ViewModels"
        mc:Ignorable="d"
        Title="WindowMover — Monitor Layout Manager"
        Height="650" Width="1000" MinHeight="450" MinWidth="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📷 Capture Layout" Command="{Binding CaptureLayoutCommand}"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                    <Button Content="↻ Refresh Apps" Command="{Binding RefreshAppsCommand}"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                    <Button Content="▶ Apply Now" Command="{Binding ApplyNowCommand}"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0" />
                    <Button Content="💾 Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource ActionButton}" />
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="WindowMover" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding CurrentSetupName, StringFormat='Current Setup: {0}'}"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content: Unassigned apps + Monitor columns -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left panel: Unassigned apps -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Margin="0,0,6,0" Padding="12"
                    AllowDrop="True"
                    DragOver="UnassignedPanel_DragOver"
                    DragLeave="UnassignedPanel_DragLeave"
                    Drop="UnassignedPanel_Drop"
                    x:Name="UnassignedPanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 Unassigned Apps"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding UnassignedApps}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             x:Name="UnassignedAppsList">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceLightBrush}"
                                        CornerRadius="4" Padding="10,8" Margin="0,2"
                                        Cursor="Hand"
                                        MouseMove="AppCard_MouseMove"
                                        Tag="{Binding}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="13" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ProcessName, StringFormat='({0})'}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right panel: Monitor columns -->
            <ItemsControl Grid.Column="1"
                          ItemsSource="{Binding Monitors}"
                          x:Name="MonitorsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="8" Margin="6,0" Padding="12"
                                AllowDrop="True"
                                DragOver="MonitorPanel_DragOver"
                                DragLeave="MonitorPanel_DragLeave"
                                Drop="MonitorPanel_Drop"
                                Tag="{Binding}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Monitor header -->
                                <StackPanel Grid.Row="0">
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}">
                                        <Run Text="🖥️ " />
                                        <Run Text="{Binding DisplayName, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                        <Run Text="{Binding Resolution, Mode=OneWay}" />
                                        <Run Text="{Binding IsBuiltIn, Mode=OneWay, StringFormat=' (Built-in: {0})'}" />
                                    </TextBlock>
                                </StackPanel>

                                <Separator Grid.Row="1" Margin="0,8" Background="{StaticResource SurfaceLightBrush}" />

                                <!-- Assigned apps list -->
                                <ListBox Grid.Row="2"
                                         ItemsSource="{Binding AssignedApps}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceLightBrush}"
                                                    CornerRadius="4" Padding="10,8" Margin="0,2"
                                                    Cursor="Hand"
                                                    MouseMove="AppCard_MouseMove"
                                                    Tag="{Binding}">
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Content="✕"
                                                            FontSize="10" Padding="4,2"
                                                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                                            BorderThickness="0" Cursor="Hand"
                                                            Click="RemoveApp_Click"
                                                            Tag="{Binding}" VerticalAlignment="Top" />
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontSize="13" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding ProcessName, StringFormat='({0})'}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>

                                <!-- Empty state overlay -->
                                <TextBlock Grid.Row="2"
                                           Text="Drag apps here"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" FontStyle="Italic"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.6"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AssignedApps.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="12,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding UnsavedIndicator}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           Margin="12,0,0,0" />
                <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0">
                    <Hyperlink Click="About_Click"
                               Foreground="#607090" TextDecorations="None"
                               FontSize="11">About</Hyperlink>
                </TextBlock>
                <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0">
                    <Hyperlink Click="Profiles_Click"
                               Foreground="#607090" TextDecorations="None"
                               FontSize="11">Profiles</Hyperlink>
                </TextBlock>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
